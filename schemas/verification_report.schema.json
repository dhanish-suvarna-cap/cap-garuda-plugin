{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Verification Report",
  "description": "Output from ProductEx verifier or guardrail checker",
  "type": "object",
  "required": ["phase", "type", "status", "timestamp"],
  "properties": {
    "phase": { "type": "string" },
    "type": { "type": "string", "enum": ["productex", "guardrail"] },
    "status": { "type": "string", "enum": ["approved", "changes_needed"] },
    "fulfilled": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "evidence": { "type": "string" }
        }
      }
    },
    "missing": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "evidence": { "type": "string" }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "source_a": { "type": "string" },
          "source_b": { "type": "string" }
        }
      }
    },
    "guardrail_violations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "guardrail_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["CRITICAL", "HIGH"] },
          "file": { "type": "string" },
          "line": { "type": ["integer", "null"] },
          "description": { "type": "string" },
          "fix_suggestion": { "type": "string" }
        }
      }
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "guardrail_warnings": { "type": "array", "items": { "type": "string" } }
  }
}
