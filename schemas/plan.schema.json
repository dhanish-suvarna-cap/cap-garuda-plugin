{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dev Plan",
  "description": "File-by-file implementation plan generated by dev-planner agent",
  "type": "object",
  "required": ["intent", "target_path", "files", "planned_at"],
  "properties": {
    "intent": { "type": "string", "enum": ["CREATE", "UPDATE"] },
    "target_path": { "type": "string", "description": "e.g., app/components/organisms/MyFeature" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "operation", "description"],
        "properties": {
          "path": { "type": "string" },
          "operation": { "type": "string", "enum": ["create", "modify"] },
          "description": { "type": "string" },
          "content_plan": {
            "type": "object",
            "description": "Structured plan for file contents — varies by file type",
            "properties": {
              "action_types": { "type": "array", "items": { "type": "string" } },
              "action_creators": { "type": "array", "items": { "type": "string" } },
              "initial_state_keys": { "type": "array", "items": { "type": "string" } },
              "reducer_cases": { "type": "array", "items": { "type": "string" } },
              "saga_workers": { "type": "array", "items": { "type": "string" } },
              "saga_watchers": { "type": "array", "items": { "type": "string" } },
              "selectors": { "type": "array", "items": { "type": "string" } },
              "cap_components": { "type": "array", "items": { "type": "string" } },
              "style_classes": { "type": "array", "items": { "type": "string" } },
              "messages": { "type": "array", "items": { "type": "string" } },
              "jsx_structure": { "type": "string" },
              "compose_chain": { "type": "array", "items": { "type": "string" } }
            }
          },
          "preserve_items": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Elements that must NOT be changed (UPDATE mode only)"
          }
        }
      }
    },
    "component_tree": {
      "type": "object",
      "properties": {
        "root": { "type": "string" },
        "children": { "type": "array", "items": { "type": "string" } }
      }
    },
    "data_flow": { "type": "string" },
    "risk_items": { "type": "array", "items": { "type": "string" } },
    "uncertain": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "element": { "type": "string" },
          "missing": { "type": "string" }
        }
      }
    },
    "planned_at": { "type": "string", "format": "date-time" }
  }
}
